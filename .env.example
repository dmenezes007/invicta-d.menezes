# Endpoint do Formspree para envio automático do formulário de agendamento.
# Sem esta variável configurada, o formulário abre o cliente de e-mail como fallback.
#
# Como configurar:
# 1. Crie uma conta gratuita em https://formspree.io
# 2. Crie um novo Form e defina o e-mail de destino como davison.menezes@gmail.com
# 3. Copie o endpoint gerado (ex: https://formspree.io/f/xpzvwbkq)
# 4. Cole abaixo e adicione esta variável também nas configurações do projeto na Vercel
VITE_FORMSPREE_ENDPOINT="https://formspree.io/f/SEU_FORM_ID"
